# ═══════════════════════════════════════════════════════════
# itappens.ai — Environment Variables
# Copy this file to .env and fill in all values before running.
# ═══════════════════════════════════════════════════════════

# ── AI APIs ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=           # console.anthropic.com
OPENAI_API_KEY=              # platform.openai.com (GPT-4o fallback)
FALLBACK_ENABLED=true        # Switch to GPT-4o if Claude is down

# ── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=          # @BotFather on Telegram
TELEGRAM_CHAT_ID=            # From api.telegram.org/bot<TOKEN>/getUpdates

# ── Gmail ───────────────────────────────────────────────────
GMAIL_SENDER_EMAIL=          # Your Gmail address

# ── Twitter / X ─────────────────────────────────────────────
TWITTER_API_KEY=             # developer.twitter.com
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_USERNAME=            # Without @

# ── External Services ───────────────────────────────────────
SERPER_API_KEY=              # serper.dev (free 2500/mo)
GITHUB_TOKEN=                # github.com/settings/tokens
GITHUB_REPO=                 # username/repo-name

# ── Cost & Budget ───────────────────────────────────────────
DAILY_BUDGET_USD=20.00       # Hard stop limit per day
ALERT_THRESHOLD_USD=15.00    # Warning threshold

# ── Sales Automation ────────────────────────────────────────
AUTO_SEND_HOT_LEADS=false    # Auto-send hot lead replies after 2hrs
CALENDLY_LINK=               # Your Calendly booking link

# ── Quality & Dashboard ─────────────────────────────────────
QUALITY_AUTO_APPROVE=9       # Auto-approve outputs scoring this or above
DASHBOARD_PORT=8000          # FastAPI dashboard port

# ── Exit Interview ──────────────────────────────────────────
FOUNDER_NAME=                # Your first name (used in exit interview)
FOUNDER_EMAIL=               # Your personal email (not no-reply)
