generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuditPlan {
  FREE
  STARTER
  GROWTH
  AUTHORITY
}

enum AuditStatus {
  LEAD_CREATED
  AWAITING_PAYMENT
  PAYMENT_CONFIRMED
  RUNNING
  COMPLETED
  FAILED
}

enum PaymentStatus {
  NOT_REQUIRED
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  RAZORPAY
}

model Audit {
  id                 String          @id @default(cuid())
  siteUrl            String
  normalizedDomain   String
  email              String
  companyName        String?
  targetKeywords     String[]
  shareToken         String          @unique
  plan               AuditPlan
  status             AuditStatus     @default(LEAD_CREATED)
  paymentStatus      PaymentStatus   @default(NOT_REQUIRED)
  paymentProvider    PaymentProvider?
  checkoutSessionId  String?         @unique
  paymentOrderId     String?         @unique
  paymentId          String?
  amount             Int             @default(0)
  currency           String          @default("INR")
  crawlDepth         Int             @default(5)
  freeScore          Int?
  fullScore          Int?
  submittedIpHash    String?
  captchaVerifiedAt  DateTime?
  summaryJson        Json?
  reportJson         Json?
  reportHtml         String?
  errorMessage       String?
  paymentCompletedAt DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  events             AuditEvent[]

  @@index([email, createdAt])
  @@index([normalizedDomain, createdAt])
  @@index([status, createdAt])
}

model AuditEvent {
  id        String   @id @default(cuid())
  auditId   String
  type      String
  payload   Json?
  createdAt DateTime @default(now())
  audit     Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@index([auditId, createdAt])
}

model Lead {
  id               String    @id @default(cuid())
  name             String
  email            String
  company          String
  website          String
  industry         String
  targetQueries    Json
  status           String    @default("new")
  geoScore         Int?
  geoReport        Json?
  
  // Lead OS Additions
  source           String    @default("manual") // apollo, organic_search, linkedin, manual
  automationStatus String    @default("pending") // pending, scoring, nurturing, converted
  externalId       String?   // Apollo or Notion ID
  enrichedData     Json?     // Company size, revenue, etc.
  competitors      String[]  // Competitor domains for FOMO alerts

  createdAt        DateTime  @default(now())
  lastContactedAt  DateTime?
  updatedAt        DateTime  @updatedAt
}

enum ClientStatus {
  AWAITING_PAYMENT
  ACTIVE
  PAUSED
  CANCELLED
}

model ClientProfile {
  id                String       @id @default(cuid())
  businessName      String
  websiteUrl        String
  email             String       @unique
  industry          String
  niche             String
  targetAudience    String
  toneOfVoice       String       @default("Professional & Authoritative")
  
  // Buffer Credentials
  bufferAccessToken String?
  linkedinProfileId String?
  twitterProfileId  String?
  instagramProfileId String?
  
  status            ClientStatus @default(AWAITING_PAYMENT)
  token             String       @unique @default(cuid()) // For the client portal link
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  
  // History of posts
  posts             ClientPost[]
}

model ClientPost {
  id              String        @id @default(cuid())
  clientId        String
  client          ClientProfile @relation(fields: [clientId], references: [id])
  platform        String        // linkedin, twitter, instagram
  content         String
  status          String        @default("scheduled") // scheduled, published, failed
  publishedAt     DateTime?
  bufferId        String?
  errorMessage    String?
  createdAt       DateTime      @default(now())
}

model EmailOTP {
  id        String   @id @default(cuid())
  email     String   @unique
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// AEO Content Engine (Blogauto.ai equivalent)
// ==========================================

model UserCredits {
  id               String   @id @default(cuid())
  email            String   @unique // We use Auth0 email as primary identifier
  balance          Int      @default(0)
  stripeCustomerId String?  @unique
  updatedAt        DateTime @updatedAt
  transactions     CreditTransaction[]
}

model CreditTransaction {
  id              String   @id @default(cuid())
  userEmail       String
  amount          Int
  stripeSessionId String?  @unique
  createdAt       DateTime @default(now())

  user            UserCredits @relation(fields: [userEmail], references: [email])
}

model WordPressSite {
  id               String   @id @default(cuid())
  email            String
  url              String
  appUser          String
  appToken         String   // Encrypted or secure storage
  toneOfVoice      String?  @default("Professional and Authoritative")
  targetAudience   String?  @default("General Audience")
  formattingRules  String?
  createdAt        DateTime @default(now())
  articles         AeoArticle[]
}

model AeoArticle {
  id          String   @id @default(cuid())
  siteId      String
  email       String
  topic       String
  targetQuery String
  status      String   @default("PENDING") // PENDING, GENERATING, PUBLISHED, FAILED
  wpPostId    Int?
  scheduledFor DateTime?
  seedKeyword String?
  isPaused    Boolean  @default(false)
  ecommerceUrl String?
  createdAt   DateTime @default(now())

  site        WordPressSite @relation(fields: [siteId], references: [id])
}
